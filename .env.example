# ============================================
# TradingView-IBKR Bridge 環境變數設定範本
# 複製此檔案為 .env 並填入實際值
# cp .env.example .env
# ============================================

# --- Bridge Server 必要設定 ---

# Webhook 驗證密鑰：用於驗證 TradingView 請求的合法性
# TradingView Alert URL 格式：https://your-domain/webhook?token=此密鑰
WEBHOOK_TOKEN=your-secret-token-here

# --- IB Gateway 容器設定 ---

# Interactive Brokers 帳號
IB_ACCOUNT=your-ib-account

# Interactive Brokers 密碼
IB_PASSWORD=your-ib-password

# 交易模式：paper（模擬交易）或 live（實盤交易）
TRADING_MODE=paper

# --- Discord 通知設定（選用） ---

# Discord Webhook URL：用於推送交易通知與錯誤警告
# 未設定時將跳過通知功能
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-url

# --- 交易參數（選用，有預設值） ---

# 使用資產比例：0.0 ~ 1.0，預設 0.95（95%）
# 計算公式：目標股數 = floor(帳戶淨值 × USE_EQUITY_PCT ÷ TQQQ 市價)
USE_EQUITY_PCT=0.95

# --- IB Gateway 連線設定（Docker Compose 內部使用，通常不需修改） ---

# IB Gateway 主機位址（Docker 內部網路服務名稱）
IB_HOST=ib-gateway

# IB Gateway 連接埠（4002 = Paper 模式，4001 = Live 模式）
IB_PORT=4002

# IB API Client ID
IB_CLIENT_ID=1
